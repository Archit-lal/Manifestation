# Twilio WhatsApp sandbox only (no SMS).
# Caregiver WhatsApp must join sandbox (join + keyword to +1 415-523-8886).

USE_TWILIO_WHATSAPP_SANDBOX=1
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
CAREGIVER_PHONE_NUMBER=

# Optional. Same intent twice inside this window is blocked (default 60000).
# ALERT_COOLDOWN_MS=60000

# Railway sets PORT
# HOST=0.0.0.0
